generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserRole {
  SUPER_ADMIN
  TENANT_OWNER
  FARM_MANAGER
  ACCOUNTANT
  FIELD_OFFICER
  WORKER
}

enum UserStatus {
  ACTIVE
  INVITED
  INACTIVE
}

enum FarmStatus {
  ACTIVE
  INACTIVE
}

enum FieldStatus {
  AVAILABLE
  PLANTED
  FALLOW
  MAINTENANCE
}

enum SeasonStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum CropPlanStatus {
  PLANNED
  PLANTED
  GROWING
  HARVESTED
  FAILED
}

enum ActivityType {
  LAND_PREPARATION
  PLANTING
  WEEDING
  IRRIGATION
  FERTILIZER_APPLICATION
  PESTICIDE_APPLICATION
  HARVESTING
  SCOUTING
  MAINTENANCE
  OTHER
}

enum ActivityStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ExpenseCategory {
  LABOR
  SEEDS
  FERTILIZER
  CHEMICALS
  TRANSPORT
  UTILITIES
  MACHINERY_MAINTENANCE
  MISCELLANEOUS
}

enum InventoryItemType {
  SEED
  FERTILIZER
  CHEMICAL
  TOOL
  FUEL
  OTHER
}

enum InventoryTransactionType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
}

enum UnitOfMeasure {
  KG
  TON
  LITRE
  BAG
  UNIT
  HECTARE
  ACRE
}

enum YieldQualityGrade {
  PREMIUM
  STANDARD
  SUBSTANDARD
}

model Tenant {
  id           String         @id @default(uuid()) @db.Uuid
  name         String
  slug         String         @unique
  legalName    String?        @map("legal_name")
  email        String?
  phone        String?
  country      String?
  state        String?
  city         String?
  address      String?
  status       TenantStatus   @default(ACTIVE)
  isActive     Boolean        @default(true) @map("is_active")
  settings     TenantSettings?
  users        User[]
  farms        Farm[]
  fields       Field[]
  seasons      Season[]
  cropPlans    CropPlan[]
  activities   FarmActivity[]
  expenses     Expense[]
  yields       YieldRecord[]
  inventory    InventoryItem[]
  transactions InventoryTransaction[]
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  deletedAt    DateTime?      @map("deleted_at")

  @@index([status])
  @@index([deletedAt])
}

model TenantSettings {
  id                      String   @id @default(uuid()) @db.Uuid
  tenantId                String   @unique @db.Uuid @map("tenant_id")
  currency                String   @default("NGN")
  timezone                String   @default("Africa/Lagos")
  financialYearStartMonth Int      @default(1) @map("financial_year_start_month")
  dateFormat              String   @default("YYYY-MM-DD") @map("date_format")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")
  tenant                  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model User {
  id                 String         @id @default(uuid()) @db.Uuid
  tenantId           String?        @db.Uuid @map("tenant_id")
  email              String         @unique
  passwordHash       String         @map("password_hash")
  refreshTokenHash   String?        @map("refresh_token_hash")
  firstName          String         @map("first_name")
  lastName           String         @map("last_name")
  phone              String?
  jobTitle           String?        @map("job_title")
  role               UserRole
  status             UserStatus     @default(ACTIVE)
  isActive           Boolean        @default(true) @map("is_active")
  lastLoginAt        DateTime?      @map("last_login_at")
  createdById        String?        @db.Uuid @map("created_by_id")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  deletedAt          DateTime?      @map("deleted_at")
  tenant             Tenant?        @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  createdBy          User?          @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers       User[]         @relation("UserCreatedBy")
  assignedActivities FarmActivity[] @relation("ActivityAssignee")

  @@index([tenantId])
  @@index([tenantId, role])
  @@index([tenantId, status])
  @@index([deletedAt])
}

model Farm {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid @map("tenant_id")
  name           String
  code           String?
  description    String?
  address        String?
  country        String?
  state          String?
  city           String?
  latitude       Decimal?     @db.Decimal(10, 7)
  longitude      Decimal?     @db.Decimal(10, 7)
  sizeInHectares Decimal?     @db.Decimal(12, 2) @map("size_in_hectares")
  status         FarmStatus   @default(ACTIVE)
  metadata       Json?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fields         Field[]
  seasons        Season[]
  cropPlans      CropPlan[]
  activities     FarmActivity[]
  expenses       Expense[]
  yields         YieldRecord[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([deletedAt])
}

model Field {
  id             String      @id @default(uuid()) @db.Uuid
  tenantId       String      @db.Uuid @map("tenant_id")
  farmId         String      @db.Uuid @map("farm_id")
  name           String
  code           String?
  sizeInHectares Decimal?    @db.Decimal(12, 2) @map("size_in_hectares")
  soilType       String?     @map("soil_type")
  latitude       Decimal?    @db.Decimal(10, 7)
  longitude      Decimal?    @db.Decimal(10, 7)
  status         FieldStatus @default(AVAILABLE)
  metadata       Json?
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  deletedAt      DateTime?   @map("deleted_at")
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  farm           Farm        @relation(fields: [farmId], references: [id], onDelete: Cascade)
  cropPlans      CropPlan[]
  activities     FarmActivity[]
  expenses       Expense[]
  yields         YieldRecord[]

  @@index([tenantId])
  @@index([farmId])
  @@index([tenantId, farmId])
  @@index([deletedAt])
}

model Season {
  id         String       @id @default(uuid()) @db.Uuid
  tenantId   String       @db.Uuid @map("tenant_id")
  farmId     String?      @db.Uuid @map("farm_id")
  name       String
  code       String?
  startDate  DateTime     @map("start_date")
  endDate    DateTime?    @map("end_date")
  status     SeasonStatus @default(PLANNED)
  notes      String?
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  deletedAt  DateTime?    @map("deleted_at")
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  farm       Farm?        @relation(fields: [farmId], references: [id], onDelete: SetNull)
  cropPlans  CropPlan[]
  activities FarmActivity[]
  expenses   Expense[]
  yields     YieldRecord[]

  @@index([tenantId])
  @@index([farmId])
  @@index([tenantId, status])
  @@index([deletedAt])
}

model CropPlan {
  id                  String         @id @default(uuid()) @db.Uuid
  tenantId            String         @db.Uuid @map("tenant_id")
  farmId              String         @db.Uuid @map("farm_id")
  fieldId             String         @db.Uuid @map("field_id")
  seasonId            String         @db.Uuid @map("season_id")
  name                String
  variety             String?
  plantingDate        DateTime?      @map("planting_date")
  expectedHarvestDate DateTime?      @map("expected_harvest_date")
  actualHarvestDate   DateTime?      @map("actual_harvest_date")
  status              CropPlanStatus @default(PLANNED)
  areaCultivated      Decimal?       @db.Decimal(12, 2) @map("area_cultivated")
  notes               String?
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")
  deletedAt           DateTime?      @map("deleted_at")
  tenant              Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  farm                Farm           @relation(fields: [farmId], references: [id], onDelete: Cascade)
  field               Field          @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  season              Season         @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  activities          FarmActivity[]
  expenses            Expense[]
  yields              YieldRecord[]

  @@index([tenantId])
  @@index([farmId])
  @@index([fieldId])
  @@index([seasonId])
  @@index([tenantId, status])
  @@index([deletedAt])
}

model FarmActivity {
  id                    String                 @id @default(uuid()) @db.Uuid
  tenantId              String                 @db.Uuid @map("tenant_id")
  farmId                String                 @db.Uuid @map("farm_id")
  fieldId               String?                @db.Uuid @map("field_id")
  seasonId              String?                @db.Uuid @map("season_id")
  cropPlanId            String?                @db.Uuid @map("crop_plan_id")
  assignedUserId        String?                @db.Uuid @map("assigned_user_id")
  activityType          ActivityType           @map("activity_type")
  status                ActivityStatus         @default(PLANNED)
  scheduledDate         DateTime               @map("scheduled_date")
  completedDate         DateTime?              @map("completed_date")
  notes                 String?
  estimatedCost         Decimal?               @db.Decimal(12, 2) @map("estimated_cost")
  actualCost            Decimal?               @db.Decimal(12, 2) @map("actual_cost")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  deletedAt             DateTime?              @map("deleted_at")
  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  farm                  Farm                   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  field                 Field?                 @relation(fields: [fieldId], references: [id], onDelete: SetNull)
  season                Season?                @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  cropPlan              CropPlan?              @relation(fields: [cropPlanId], references: [id], onDelete: SetNull)
  assignedUser          User?                  @relation("ActivityAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  expenses              Expense[]
  inventoryTransactions InventoryTransaction[]

  @@index([tenantId])
  @@index([farmId])
  @@index([fieldId])
  @@index([seasonId])
  @@index([cropPlanId])
  @@index([assignedUserId])
  @@index([scheduledDate])
  @@index([tenantId, status])
  @@index([deletedAt])
}

model Expense {
  id                    String                 @id @default(uuid()) @db.Uuid
  tenantId              String                 @db.Uuid @map("tenant_id")
  farmId                String                 @db.Uuid @map("farm_id")
  fieldId               String?                @db.Uuid @map("field_id")
  seasonId              String?                @db.Uuid @map("season_id")
  cropPlanId            String?                @db.Uuid @map("crop_plan_id")
  activityId            String?                @db.Uuid @map("activity_id")
  category              ExpenseCategory
  description           String?
  amount                Decimal                @db.Decimal(14, 2)
  paymentDate           DateTime               @map("payment_date")
  vendor                String?
  receiptUrl            String?                @map("receipt_url")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  deletedAt             DateTime?              @map("deleted_at")
  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  farm                  Farm                   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  field                 Field?                 @relation(fields: [fieldId], references: [id], onDelete: SetNull)
  season                Season?                @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  cropPlan              CropPlan?              @relation(fields: [cropPlanId], references: [id], onDelete: SetNull)
  activity              FarmActivity?          @relation(fields: [activityId], references: [id], onDelete: SetNull)
  inventoryTransactions InventoryTransaction[]

  @@index([tenantId])
  @@index([farmId])
  @@index([fieldId])
  @@index([seasonId])
  @@index([cropPlanId])
  @@index([activityId])
  @@index([paymentDate])
  @@index([tenantId, category])
  @@index([deletedAt])
}

model YieldRecord {
  id           String             @id @default(uuid()) @db.Uuid
  tenantId     String             @db.Uuid @map("tenant_id")
  farmId       String             @db.Uuid @map("farm_id")
  fieldId      String             @db.Uuid @map("field_id")
  seasonId     String             @db.Uuid @map("season_id")
  cropPlanId   String             @db.Uuid @map("crop_plan_id")
  harvestDate  DateTime           @map("harvest_date")
  quantity     Decimal            @db.Decimal(14, 2)
  unit         UnitOfMeasure
  qualityGrade YieldQualityGrade? @map("quality_grade")
  lossWaste    Decimal?           @db.Decimal(14, 2) @map("loss_waste")
  notes        String?
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  deletedAt    DateTime?          @map("deleted_at")
  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  farm         Farm               @relation(fields: [farmId], references: [id], onDelete: Cascade)
  field        Field              @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  season       Season             @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  cropPlan     CropPlan           @relation(fields: [cropPlanId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([farmId])
  @@index([fieldId])
  @@index([seasonId])
  @@index([cropPlanId])
  @@index([harvestDate])
  @@index([deletedAt])
}

model InventoryItem {
  id             String                 @id @default(uuid()) @db.Uuid
  tenantId       String                 @db.Uuid @map("tenant_id")
  name           String
  sku            String?
  itemType       InventoryItemType      @map("item_type")
  unit           UnitOfMeasure
  quantityOnHand Decimal                @default(0) @db.Decimal(14, 2) @map("quantity_on_hand")
  reorderLevel   Decimal?               @db.Decimal(14, 2) @map("reorder_level")
  supplier       String?
  notes          String?
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")
  deletedAt      DateTime?              @map("deleted_at")
  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions   InventoryTransaction[]

  @@index([tenantId])
  @@index([tenantId, itemType])
  @@index([deletedAt])
}

model InventoryTransaction {
  id              String                   @id @default(uuid()) @db.Uuid
  tenantId        String                   @db.Uuid @map("tenant_id")
  inventoryItemId String                   @db.Uuid @map("inventory_item_id")
  expenseId       String?                  @db.Uuid @map("expense_id")
  activityId      String?                  @db.Uuid @map("activity_id")
  transactionType InventoryTransactionType @map("transaction_type")
  quantity        Decimal                  @db.Decimal(14, 2)
  unitCost        Decimal?                 @db.Decimal(14, 2) @map("unit_cost")
  transactionDate DateTime                 @map("transaction_date")
  notes           String?
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  deletedAt       DateTime?                @map("deleted_at")
  tenant          Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem            @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  expense         Expense?                 @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  activity        FarmActivity?            @relation(fields: [activityId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([inventoryItemId])
  @@index([expenseId])
  @@index([activityId])
  @@index([transactionDate])
  @@index([deletedAt])
}
